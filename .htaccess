<IfModule mod_rewrite.c>
RewriteEngine On

# Standard routing - No aggressive redirects for now
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . index.php [L,QSA]
</IfModule>

<FilesMatch "\.(env|sql|lock|md|ya?ml|sh|ini|log|dist|bak)$|^bumame-credentials\.json$|^composer\.json$|^Dockerfile$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
