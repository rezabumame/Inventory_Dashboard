{
  "version": 2,
  "builds": [
    { "src": "index.php", "use": "vercel-php@0.7.2" },
    { "src": "api/*.php", "use": "vercel-php@0.7.2" },
    { "src": "actions/*.php", "use": "vercel-php@0.7.2" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/api/(.*).php", "dest": "/api/$1.php" },
    { "src": "/actions/(.*).php", "dest": "/actions/$1.php" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
