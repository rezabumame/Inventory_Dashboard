{
  "version": 2,
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.7.2" },
    "actions/*.php": { "runtime": "vercel-php@0.7.2" },
    "scripts/*.php": { "runtime": "vercel-php@0.7.2" },
    "*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/api/(.*).php", "dest": "/api/$1.php" },
    { "src": "/actions/(.*).php", "dest": "/actions/$1.php" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
